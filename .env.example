# ════════════════════════════════════════════════════════════════
# CONFIGURAÇÃO DE SEGURANÇA - LAUDOS GENERATOR
# ════════════════════════════════════════════════════════════════
# Copiar este arquivo para .env e preencher com valores seguros

# Chave segura para sessions (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=seu_secret_key_seguro_aqui_com_32_bytes_aleatorios

# Senha padrão para usuário admin (MUDE NA PRIMEIRA LOGIN!)
# Requisito: mínimo 8 caracteres
ADMIN_PASSWORD=ChangeMe@123

# Caminho de rede para backup (opcional)
# NETWORK_PATH=\\servidor\compartilhamento\laudos

# ════════════════════════════════════════════════════════════════
# INSTRUÇÕES:
# 1. Renomeie este arquivo de .env.example para .env
# 2. Gere uma SECRET_KEY forte: python -c "import secrets; print(secrets.token_hex(32))"
# 3. Defina uma senha admin segura (mínimo 8 caracteres)
# 4. O servidor usará automaticamente essas variáveis
# ════════════════════════════════════════════════════════════════
